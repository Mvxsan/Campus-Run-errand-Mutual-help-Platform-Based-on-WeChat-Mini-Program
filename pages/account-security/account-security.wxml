<view class="container">
  <!-- 页面头部 -->
  <view class="header">
    <view class="back-btn" bindtap="navigateBack">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">账号与安全</text>
    <view class="header-right"></view>
  </view>
  
  <!-- 用户基本信息 -->
  <view class="user-info-section">
    <view class="user-avatar">
      <image class="avatar-img" src="{{userInfo.avatar && (userInfo.avatar.indexOf('http://tmp/') === 0 || userInfo.avatar.indexOf('_tmp_') > 0) ? 'https://img.icons8.com/color/48/000000/user.png' : userInfo.avatar || 'https://img.icons8.com/color/48/000000/user.png'}}" mode="aspectFill"></image>
    </view>
    <view class="user-details">
      <text class="user-name">{{userInfo.nickname}}</text>
      <text class="user-phone">{{userInfo.phone}}</text>
    </view>
  </view>
  
  <!-- 个人信息设置 -->
  <view class="security-section">
    <view class="section-title">个人信息</view>
    
    <view class="setting-item" bindtap="navigateToEditProfile">
      <view class="setting-label">编辑个人资料</view>
      <view class="setting-arrow">
        <text class="arrow-text">→</text>
      </view>
    </view>
  </view>
  
  <!-- 安全设置 -->
  <view class="security-section">
    <view class="section-title">安全设置</view>
    
    <view class="setting-item" bindtap="showPasswordChangeDialog">
      <view class="setting-label">修改密码</view>
      <view class="setting-arrow">
        <text class="arrow-text">→</text>
      </view>
    </view>
  </view>
  
  <!-- 密码修改弹窗 -->
  <view class="modal-mask" wx:if="{{showPasswordDialog}}" bindtap="hidePasswordChangeDialog"></view>
  <view class="modal-content" wx:if="{{showPasswordDialog}}">
    <view class="modal-header">
      <text class="modal-title">修改密码</text>
      <text class="modal-close" bindtap="hidePasswordChangeDialog">×</text>
    </view>
    <view class="modal-body">
      <view class="form-item">
        <view class="form-label">当前密码</view>
        <input class="form-input" placeholder="请输入当前密码" password bindinput="handleOldPasswordInput" value="{{oldPassword}}"/>
      </view>
      <view class="form-item">
        <view class="form-label">新密码</view>
        <input class="form-input" placeholder="请输入新密码" password bindinput="handleNewPasswordInput" value="{{newPassword}}"/>
      </view>
      <view class="form-item">
        <view class="form-label">确认新密码</view>
        <input class="form-input" placeholder="请再次输入新密码" password bindinput="handleConfirmPasswordInput" value="{{confirmPassword}}"/>
      </view>
    </view>
    <view class="modal-footer">
      <button class="cancel-btn" bindtap="hidePasswordChangeDialog">取消</button>
      <button class="confirm-btn" bindtap="handlePasswordChange">确认修改</button>
    </view>
  </view>
</view>