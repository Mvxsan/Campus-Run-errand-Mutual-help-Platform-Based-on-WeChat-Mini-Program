.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 页面头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  height: 100rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e5e5e5;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333333;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.header-right {
  width: 60rpx;
}

/* 用户基本信息 */
.user-info-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #f0f0f0;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.user-phone {
  font-size: 24rpx;
  color: #666666;
}

.user-role {
  font-size: 20rpx;
  color: #07c160;
  background-color: #f0f9eb;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  align-self: flex-start;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.chat-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 160rpx;
  height: 72rpx;
  padding: 0;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 36rpx;
  font-size: 24rpx;
  border: none;
  outline: none;
}

.chat-icon {
  font-size: 28rpx;
}

.follow-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 160rpx;
  height: 72rpx;
  padding: 0;
  background-color: #1890ff;
  color: #ffffff;
  border-radius: 36rpx;
  font-size: 24rpx;
  border: none;
  outline: none;
}

.follow-icon {
  font-size: 28rpx;
}

.unfollow-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 160rpx;
  height: 72rpx;
  padding: 0;
  background-color: #f0f0f0;
  color: #666666;
  border-radius: 36rpx;
  font-size: 24rpx;
  border: none;
  outline: none;
}

.unfollow-icon {
  font-size: 28rpx;
}

.like-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 160rpx;
  height: 72rpx;
  padding: 0;
  background-color: #ff85c0;
  color: #ffffff;
  border-radius: 36rpx;
  font-size: 24rpx;
  border: none;
  outline: none;
}

.liked-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 160rpx;
  height: 72rpx;
  padding: 0;
  background-color: #f0f0f0;
  color: #666666;
  border-radius: 36rpx;
  font-size: 24rpx;
  border: none;
  outline: none;
}

.like-icon {
  font-size: 28rpx;
}

.like-count {
  font-size: 20rpx;
  margin-left: 4rpx;
}

/* 用户统计信息 */
.stats-section {
  padding: 32rpx;
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stats-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.stats-label {
  font-size: 20rpx;
  color: #666666;
}

/* 任务列表 */
.tasks-section {
  padding: 32rpx;
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  font-size: 24rpx;
  color: #07c160;
}

.tasks-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-item {
  padding: 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-title {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

.task-reward {
  font-size: 20rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.task-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.task-status {
  font-size: 20rpx;
  color: #666666;
  padding: 4rpx 12rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.status-accepted {
  background-color: #fff7e6;
  color: #fa8c16;
}

.status-picked {
  background-color: #e6f7ff;
  color: #1890ff;
}

.status-delivered {
  background-color: #f6ffed;
  color: #52c41a;
}

.status-completed {
  background-color: #f6ffed;
  color: #52c41a;
}

.status-canceled {
  background-color: #fff2f0;
  color: #ff4d4f;
}

.status-banned {
  background-color: #f5f0ff;
  color: #722ed1;
}

.empty-tasks {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.empty-text {
  font-size: 24rpx;
  color: #999999;
}

/* 管理员角色管理按钮 */
.admin-role-buttons {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
  width: 100%;
}

.role-btn {
  width: 240rpx;
  height: 60rpx;
  font-size: 24rpx;
  line-height: 60rpx;
  background-color: #1890ff;
  color: #ffffff;
  border-radius: 30rpx;
  border: none;
  outline: none;
}
