<view class="container">
  <!-- 页面头部 -->
  <view class="header">
    <view class="back-btn" bindtap="navigateBack">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">评价</text>
    <view class="header-right"></view>
  </view>
  
  <!-- 任务信息 -->
  <view class="task-info">
    <text class="task-title">{{task.title}}</text>
    <text class="task-amount">任务金额：¥{{task.reward}}</text>
  </view>
  
  <!-- 评价表单 -->
  <view class="review-form">
    <!-- 评分 -->
    <view class="rating-section">
      <text class="rating-label">评分</text>
      <view class="rating-stars">
        <text class="star {{rating >= 1 ? 'active' : ''}}" bindtap="setRating" data-rating="1">★</text>
        <text class="star {{rating >= 2 ? 'active' : ''}}" bindtap="setRating" data-rating="2">★</text>
        <text class="star {{rating >= 3 ? 'active' : ''}}" bindtap="setRating" data-rating="3">★</text>
        <text class="star {{rating >= 4 ? 'active' : ''}}" bindtap="setRating" data-rating="4">★</text>
        <text class="star {{rating >= 5 ? 'active' : ''}}" bindtap="setRating" data-rating="5">★</text>
      </view>
    </view>
    
    <!-- 评价标签 -->
    <view class="tags-section">
      <text class="tags-label">评价标签</text>
      <view class="tags-grid">
        <view 
          wx:for="{{tagsWithStatus}}" 
          wx:key="index"
          class="tag {{item.selected ? 'selected' : ''}}"
          bindtap="toggleTag" 
          data-tag="{{item.name}}"
        >{{item.name}}</view>
      </view>
    </view>
    
    <!-- 评价内容 -->
    <view class="content-section">
      <text class="content-label">评价内容</text>
      <view class="content-input-container">
        <textarea 
          class="content-input" 
          placeholder="请输入评价内容" 
          placeholder-class="content-placeholder"
          value="{{content}}"
          bindinput="handleContentInput"
        ></textarea>
        <button class="image-btn" bindtap="chooseImage">📷</button>
      </view>
      <!-- 已选择的图片 -->
      <view wx:if="{{images.length > 0}}" class="selected-images">
        <view wx:for="{{images}}" wx:key="index" class="image-item">
          <image class="selected-image" src="{{item}}" mode="aspectFill"></image>
          <view class="image-remove" bindtap="removeImage" data-index="{{index}}">×</view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 提交按钮 -->
  <view class="button-section">
    <button 
      class="submit-btn" 
      bindtap="submitReview"
      disabled="{{!canSubmit}}"
    >
      提交评价
    </button>
  </view>
</view>