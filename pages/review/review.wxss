.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 页面头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  height: 100rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e5e5e5;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333333;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
  text-align: center;
  margin: 0 60rpx;
}

.header-right {
  width: 60rpx;
  height: 60rpx;
}

/* 任务信息 */
.task-info {
  background-color: #ffffff;
  padding: 32rpx;
  margin: 20rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
}

.task-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.task-amount {
  font-size: 24rpx;
  color: #666666;
}

/* 评价表单 */
.review-form {
  background-color: #ffffff;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

/* 评分区域 */
.rating-section {
  margin-bottom: 40rpx;
}

.rating-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}

.rating-stars {
  display: flex;
  gap: 16rpx;
}

.star {
  font-size: 48rpx;
  color: #d9d9d9;
  cursor: pointer;
  transition: all 0.3s ease;
}

.star.active {
  color: #ffd700;
  transform: scale(1.1);
}

/* 标签区域 */
.tags-section {
  margin-bottom: 40rpx;
}

.tags-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}

.tags-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 12rpx 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #666666;
  background-color: #f9f9f9;
  transition: all 0.3s ease;
}

.tag.selected {
  border-color: #1890ff;
  color: #1890ff;
  background-color: #e6f7ff;
}

/* 内容区域 */
.content-section {
  margin-bottom: 40rpx;
}

.content-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}

.content-input-container {
  position: relative;
  width: 100%;
}

.content-input {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #333333;
  resize: none;
  outline: none;
  padding-right: 80rpx;
}

.image-btn {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  width: 56rpx;
  height: 56rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  padding: 0;
  z-index: 100;
  cursor: pointer;
  opacity: 1;
  visibility: visible;
}

.selected-images {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.image-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.selected-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  object-fit: cover;
}

.image-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  cursor: pointer;
}

.content-placeholder {
  color: #999999;
}

/* 提交按钮 */
.button-section {
  padding: 0 32rpx;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  background-color: #1890ff;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 45rpx;
  transition: all 0.3s ease;
}

.submit-btn:hover {
  background-color: #40a9ff;
}

.submit-btn:active {
  background-color: #096dd9;
  transform: scale(0.98);
}

.submit-btn[disabled] {
  background-color: #d9d9d9;
  color: #ffffff;
}

.submit-btn::after {
  border-radius: 45rpx;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .star {
    font-size: 40rpx;
  }
  
  .content-input {
    min-height: 140rpx;
  }
  
  .submit-btn {
    height: 80rpx;
    font-size: 28rpx;
  }
}