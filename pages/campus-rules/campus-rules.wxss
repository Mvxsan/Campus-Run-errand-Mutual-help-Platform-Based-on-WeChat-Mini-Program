/* campus-rules.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.rules-content {
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.rules-header {
  margin-bottom: 20rpx;
}

.rules-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.rules-update-time {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.rules-body {
  line-height: 1.6;
  min-height: 400rpx;
}

.rule-item {
  display: flex;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.rule-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.rule-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
  min-width: 40rpx;
  text-align: right;
}

.rule-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  flex: 1;
}

.empty-rules {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.admin-action {
  position: fixed;
  bottom: 30rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  padding: 0 20rpx;
}

.edit-btn {
  background-color: #1890ff;
  color: white;
  border-radius: 50rpx;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
}

.edit-btn::after {
  border-radius: 50rpx;
}