/* edit-rules.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.edit-section {
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.edit-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.add-rule-btn {
  background-color: #f5f5f5;
  color: #333;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
}

.add-rule-btn::after {
  border-radius: 8rpx;
}

.edit-body {
  min-height: 500rpx;
}

.rule-item {
  margin-bottom: 30rpx;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  background-color: #fafafa;
}

.rule-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.rule-index {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

.delete-rule-btn {
  background-color: #f5f5f5;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 8rpx;
  font-size: 20rpx;
  padding: 5rpx 15rpx;
}

.delete-rule-btn::after {
  border-radius: 8rpx;
}

.rule-textarea {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  min-height: 200rpx;
  background-color: white;
}

.textarea-placeholder {
  color: #999;
}

.empty-rules {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.action-section {
  margin-top: 30rpx;
}

.save-btn {
  background-color: #f5f5f5;
  color: #333;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 20rpx;
}

.save-btn::after {
  border-radius: 8rpx;
}