.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 0 0 60rpx 0;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.back-icon {
  font-size: 32rpx;
  color: #333333;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
  text-align: center;
  margin: 0 60rpx;
}

.header-right {
  width: 60rpx;
  height: 60rpx;
}

.balance-card {
  background: #ffffff;
  margin: 40rpx 32rpx;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.balance-header {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
}

.balance-label {
  font-size: 26rpx;
  color: #8c8c8c;
}

.balance-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.balance-icon-text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

.balance-value-row {
  display: flex;
  justify-content: center;
  align-items: baseline;
}

.balance-symbol {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
  margin-right: 8rpx;
}

.balance-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #333333;
  letter-spacing: -2rpx;
}

.income-section {
  background: #ffffff;
  margin: 0 32rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.income-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.income-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.income-arrow {
  font-size: 24rpx;
  color: #bfbfbf;
}

.income-summary {
  display: flex;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.income-item {
  text-align: center;
}

.income-label {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.income-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.amount-section {
  background: #ffffff;
  margin: 0 32rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.amount-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 20rpx;
  display: block;
}

.amount-input-container {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 0 28rpx;
  height: 96rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.amount-input-container:focus-within {
  border-color: #667eea;
  background: #ffffff;
}

.amount-currency {
  font-size: 36rpx;
  font-weight: 600;
  color: #667eea;
  margin-right: 16rpx;
}

.amount-input {
  flex: 1;
  font-size: 36rpx;
  color: #333333;
  font-weight: 500;
  height: 100%;
  outline: none;
}

.amount-placeholder {
  color: #bfbfbf;
}

.quick-amount-section {
  background: #ffffff;
  margin: 0 32rpx 32rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.quick-amount-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 24rpx;
  display: block;
}

.quick-amount-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.quick-amount-item {
  height: 88rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.quick-amount-item:active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  transform: scale(0.96);
  border-color: #667eea;
}

.quick-amount-item:active .quick-amount-text {
  color: #ffffff;
}

.quick-amount-text {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.button-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.withdraw-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
}

.withdraw-btn:hover {
  background: linear-gradient(135deg, #7c8eea 0%, #865ba2 100%);
}

.withdraw-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
}

.withdraw-btn[disabled] {
  background: #d9d9d9;
  color: #ffffff;
  box-shadow: none;
}

.withdraw-btn::after {
  border-radius: 50rpx;
}

.note-section {
  background: rgba(255, 255, 255, 0.95);
  margin: 0 32rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.note-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.note-icon {
  width: 32rpx;
  height: 32rpx;
  background: #fff3cd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.note-icon-text {
  font-size: 18rpx;
  color: #856404;
  font-weight: bold;
}

.note-list {
  padding-left: 44rpx;
}

.note-content {
  font-size: 24rpx;
  color: #666666;
  line-height: 2;
  display: block;
  position: relative;
  padding-left: 24rpx;
}

.note-content::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 8rpx;
  background: #667eea;
  border-radius: 50%;
}

@media (max-width: 375px) {
  .balance-value {
    font-size: 48rpx;
  }
  
  .amount-input {
    font-size: 32rpx;
  }
  
  .quick-amount-text {
    font-size: 24rpx;
  }
  
  .withdraw-btn {
    height: 90rpx;
    font-size: 30rpx;
  }
}
