<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="navigateBack">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">资金管理</text>
    <view class="header-right"></view>
  </view>
  
  <view class="balance-card">
    <view class="balance-header">
      <text class="balance-label">可用余额</text>
    </view>
    <view class="balance-value-row">
      <text class="balance-symbol">¥</text>
      <text class="balance-value">{{userInfo.balance || 0.00}}</text>
    </view>
  </view>
  
  <view class="income-section" bindtap="navigateToIncomeDetail">
    <view class="income-header">
      <text class="income-title">收入明细</text>
      <text class="income-arrow">→</text>
    </view>
    <view class="income-summary">
      <view class="income-item">
        <text class="income-label">总收入</text>
        <text class="income-value">¥{{totalIncome || 0.00}}</text>
      </view>
      <view class="income-item">
        <text class="income-label">总提现</text>
        <text class="income-value">¥{{totalWithdrawal || 0.00}}</text>
      </view>
    </view>
  </view>
  
  <view class="amount-section">
    <text class="amount-label">提现金额</text>
    <view class="amount-input-container">
      <text class="amount-currency">¥</text>
      <input 
        class="amount-input" 
        placeholder="请输入提现金额" 
        placeholder-class="amount-placeholder"
        value="{{withdrawalAmount}}"
        bindinput="handleAmountInput"
        type="digit"
      />
    </view>
  </view>
  
  <view class="quick-amount-section">
    <text class="quick-amount-label">快速金额</text>
    <view class="quick-amount-grid">
      <view class="quick-amount-item" bindtap="setQuickAmount" data-amount="10">
        <text class="quick-amount-text">¥10</text>
      </view>
      <view class="quick-amount-item" bindtap="setQuickAmount" data-amount="50">
        <text class="quick-amount-text">¥50</text>
      </view>
      <view class="quick-amount-item" bindtap="setQuickAmount" data-amount="100">
        <text class="quick-amount-text">¥100</text>
      </view>
      <view class="quick-amount-item" bindtap="withdrawAll">
        <text class="quick-amount-text">全部</text>
      </view>
    </view>
  </view>
  
  <view class="button-section">
    <button 
      class="withdraw-btn" 
      bindtap="handleWithdrawal"
      disabled="{{!canWithdraw}}"
    >
      提现
    </button>
  </view>
  
  <view class="note-section">
    <view class="note-title">
      <view class="note-icon">
        <text class="note-icon-text">!</text>
      </view>
      <text>提现说明</text>
    </view>
    <view class="note-list">
      <text class="note-content">提现金额不能大于可用余额</text>
      <text class="note-content">提现到账时间可能需要1-3个工作日</text>
      <text class="note-content">每天最多可提现3次</text>
    </view>
  </view>
</view>
