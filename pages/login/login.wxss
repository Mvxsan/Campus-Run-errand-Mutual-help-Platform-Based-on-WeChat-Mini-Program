.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.login-form {
  width: 90%;
  max-width: 400px;
  background-color: #ffffff;
  border-radius: 12px;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.form-header {
  text-align: center;
  margin-bottom: 50rpx;
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.form-subtitle {
  font-size: 20rpx;
  color: #999999;
  display: block;
}

.form-body {
  width: 100%;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 24rpx;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  color: #333333;
  box-sizing: border-box;
}

.login-btn {
  width: 100%;
  height: 80rpx;
  background-color: #1890ff;
  color: #ffffff;
  font-size: 24rpx;
  border-radius: 8rpx;
  margin-top: 20rpx;
  margin-bottom: 30rpx;
}

.login-btn::after {
  border-radius: 8rpx;
}

.form-footer {
  text-align: center;
}

.register-link {
  font-size: 20rpx;
  color: #1890ff;
}

.register-link:hover {
  text-decoration: underline;
}