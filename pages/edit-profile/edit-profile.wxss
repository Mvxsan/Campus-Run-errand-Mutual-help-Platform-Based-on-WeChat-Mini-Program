.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.edit-profile-form {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.form-header {
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
}

.form-body {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.form-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
}

.avatar-uploader {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  object-fit: cover;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.avatar-upload-btn {
  padding: 16rpx 32rpx;
  background-color: #f0f0f0;
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

.avatar-upload-btn:hover {
  background-color: #e0e0e0;
}

.upload-text {
  font-size: 22rpx;
  color: #666666;
}

.form-input {
  padding: 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #333333;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #1890ff;
  box-shadow: 0 0 0 4rpx rgba(24, 144, 255, 0.1);
}

.form-input:disabled {
  background-color: #f5f5f5;
  color: #999999;
}

.save-btn {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: #1890ff;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.save-btn:hover {
  background-color: #40a9ff;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
}

.save-btn::after {
  border-radius: 12rpx;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .form-title {
    font-size: 28rpx;
  }
  
  .form-label {
    font-size: 22rpx;
  }
  
  .form-input {
    padding: 18rpx;
    font-size: 22rpx;
  }
  
  .save-btn {
    padding: 18rpx;
    font-size: 24rpx;
  }
  
  .avatar-img {
    width: 140rpx;
    height: 140rpx;
  }
  
  .avatar-upload-btn {
    padding: 14rpx 28rpx;
  }
  
  .upload-text {
    font-size: 20rpx;
  }
}

/* 动画效果 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.edit-profile-form {
  animation: fadeInUp 0.6s ease-out;
}