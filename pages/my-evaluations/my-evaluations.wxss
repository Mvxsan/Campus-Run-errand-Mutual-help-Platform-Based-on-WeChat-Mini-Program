.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  width: 60rpx;
}

.tabs {
  display: flex;
  background-color: #fff;
  border-bottom: 2rpx solid #eee;
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.tab.active {
  border-bottom: 4rpx solid #1890ff;
}

.tab-text {
  font-size: 30rpx;
  color: #666;
}

.tab.active .tab-text {
  color: #1890ff;
  font-weight: 600;
}

.review-list {
  flex: 1;
  padding: 20rpx;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.review-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.review-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.reviewer-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
}

.reviewer-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.reviewer-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.review-role {
  font-size: 24rpx;
  color: #999;
}

.review-time {
  font-size: 24rpx;
  color: #999;
}

.task-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.task-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.task-reward {
  font-size: 30rpx;
  color: #ff6b6b;
  font-weight: 600;
  margin-left: 20rpx;
}

.review-rating {
  margin-bottom: 20rpx;
}

.stars {
  display: flex;
  align-items: center;
}

.star {
  font-size: 36rpx;
  color: #ddd;
  margin-right: 8rpx;
}

.star.active {
  color: #ffc107;
}

.review-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.tag-item {
  background-color: #e6f7ff;
  color: #1890ff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  margin-right: 16rpx;
  margin-bottom: 10rpx;
}

.review-content {
  margin-bottom: 20rpx;
}

.content-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.review-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.review-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f0f0f0;
}