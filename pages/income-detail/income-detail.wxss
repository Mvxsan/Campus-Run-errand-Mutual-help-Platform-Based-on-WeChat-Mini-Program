.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  width: 60rpx;
}

.stats-section {
  display: flex;
  background-color: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  background-color: #eee;
  margin: 0 20rpx;
}

.income-list, .withdrawal-list {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.list-header {
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.list-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.empty-container {
  padding: 60rpx;
  display: flex;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.income-item, .withdrawal-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.income-item:last-child, .withdrawal-item:last-child {
  border-bottom: none;
}

.income-icon, .withdrawal-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #e6f7ff;
  border-radius: 50%;
  margin-right: 20rpx;
}

.withdrawal-icon {
  background-color: #fff7e6;
}

.icon-text {
  font-size: 32rpx;
}

.income-info, .withdrawal-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.income-task, .withdrawal-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.income-time, .withdrawal-time {
  font-size: 24rpx;
  color: #999;
}

.income-amount, .withdrawal-amount {
  display: flex;
  align-items: center;
}

.amount-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #52c41a;
}

.withdrawal-amount .amount-value {
  color: #ff6b6b;
}