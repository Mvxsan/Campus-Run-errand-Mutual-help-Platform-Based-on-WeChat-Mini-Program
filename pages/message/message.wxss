.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 消息类型切换 */
.message-tabs {
  display: flex;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  height: 90rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.3s ease;
  border-radius: 10rpx;
  margin: 10rpx;
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 5rpx;
  transition: all 0.3s ease;
}

.tab-text {
  font-size: 22rpx;
  color: #666666;
  transition: all 0.3s ease;
  font-weight: 500;
}

.tab-item:hover {
  background-color: #f0f8ff;
  transform: translateY(-2rpx);
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.1);
}

.tab-item.active {
  color: #1890ff;
  background-color: #e6f7ff;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.2);
  transform: translateY(-2rpx);
}

.tab-item.active .tab-text {
  font-weight: bold;
  color: #1890ff;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: #1890ff;
  border-radius: 3rpx;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 4rpx rgba(24, 144, 255, 0.4);
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 消息项 */
.message-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.message-item:hover {
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.12);
  transform: translateY(-4rpx);
}

/* 消息头像 */
.message-avatar {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

.avatar-container {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.message-item:hover .avatar-container {
  transform: scale(1.05);
}

.avatar-icon {
  font-size: 40rpx;
}

.unread-badge {
  position: absolute;
  top: 0;
  right: 0;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: #ff4d4f;
  border: 4rpx solid #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.3);
}

/* 消息内容 */
.message-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.message-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
  margin-right: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.message-time {
  font-size: 20rpx;
  color: #999999;
  flex-shrink: 0;
  white-space: nowrap;
}

.message-body {
  font-size: 22rpx;
  color: #666666;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.message-footer {
  display: flex;
  align-items: center;
}

.order-status-tag {
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.order-status-0 {
  background-color: #fff7e6;
  color: #fa8c16;
  border: 1rpx solid #ffd591;
}

.order-status-1 {
  background-color: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

.order-status-2 {
  background-color: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

.order-status-3 {
  background-color: #fff1f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
}

.order-status-4 {
  background-color: #e6f7ff;
  color: #1890ff;
  border: 1rpx solid #91d5ff;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999999;
  text-align: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
  transition: all 0.3s ease;
}

.empty-icon:hover {
  transform: scale(1.1);
}

.empty-text {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.empty-subtext {
  font-size: 22rpx;
  color: #999999;
}

/* 动画效果 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in-up {
  animation: fadeInUp 0.6s ease-out;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .tab-icon {
    font-size: 28rpx;
  }
  
  .tab-text {
    font-size: 20rpx;
  }
  
  .message-title {
    font-size: 24rpx;
  }
  
  .message-body {
    font-size: 20rpx;
  }
  
  .message-time {
    font-size: 18rpx;
  }
  
  .avatar-container {
    width: 70rpx;
    height: 70rpx;
  }
  
  .avatar-icon {
    font-size: 36rpx;
  }
  
  .empty-text {
    font-size: 24rpx;
  }
  
  .empty-subtext {
    font-size: 20rpx;
  }
}

/* 未登录提示样式 */
.login-prompt {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 60rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.prompt-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
}

.prompt-icon image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.prompt-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 50rpx;
  text-align: center;
}

.login-btn {
  width: 240rpx;
  height: 88rpx;
  background-color: #1890ff;
  color: #fff;
  font-size: 26rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.login-btn::after {
  border-radius: 44rpx;
}

.login-btn:hover {
  background-color: #40a9ff;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
}