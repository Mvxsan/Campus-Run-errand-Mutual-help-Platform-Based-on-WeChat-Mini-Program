.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 页面头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  height: 100rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e5e5e5;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333333;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
  text-align: center;
  margin: 0 60rpx;
}

.header-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-icon {
  font-size: 32rpx;
  color: #333333;
}

/* 聊天消息列表 */
.chat-list {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 消息项 */
.message-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

/* 对方消息 */
.other-message {
  align-self: flex-start;
  flex-direction: row;
}

/* 自己的消息 */
.my-message {
  align-self: flex-end;
  flex-direction: row-reverse;
}

/* 消息头像 */
.message-avatar {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #f0f0f0;
}

/* 消息内容 */
.message-content {
  max-width: 70%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* 消息气泡 */
.message-bubble {
  position: relative;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.4;
  word-wrap: break-word;
}

.message-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

/* 对方的消息气泡箭头 */
.other-message .message-bubble::before {
  content: '';
  position: absolute;
  left: -16rpx;
  top: 50%;
  transform: translateY(-50%);
  border-width: 12rpx 16rpx 12rpx 0;
  border-style: solid;
  border-color: transparent #07c160 transparent transparent;
}

/* 自己的消息气泡箭头 */
.my-message .message-bubble::before {
  content: '';
  position: absolute;
  right: -16rpx;
  top: 50%;
  transform: translateY(-50%);
  border-width: 12rpx 0 12rpx 16rpx;
  border-style: solid;
  border-color: transparent transparent transparent #07c160;
}

.message-time {
  font-size: 20rpx;
  color: #999999;
  align-self: center;
}

/* 消息输入区域 */
.input-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e5e5e5;
}

.input-container {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 16rpx;
  height: 80rpx;
}

.image-btn {
  width: 56rpx;
  height: 56rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  padding: 0;
}

.message-input {
  flex: 1;
  height: 100%;
  padding: 0 8rpx;
  background: none;
  font-size: 28rpx;
  color: #333333;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 滚动条样式 */
.chat-list::-webkit-scrollbar {
  width: 4rpx;
}

.chat-list::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 2rpx;
}

.chat-list::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 2rpx;
}

.chat-list::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}

/* 图片预览区域 */
.image-preview-container {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #e5e5e5;
}

.image-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cancel-image-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
}

/* 禁用的发送按钮 */
.send-btn[disabled] {
  background-color: #cccccc;
  color: #ffffff;
}
