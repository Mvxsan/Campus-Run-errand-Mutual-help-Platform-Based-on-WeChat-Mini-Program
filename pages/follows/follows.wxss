.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background-color: #ffffff;
  padding: 20rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  color: #333333;
}

.follows-list {
  padding: 20rpx;
}

.follow-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.follow-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
}

.follow-avatar image {
  width: 100%;
  height: 100%;
}

.follow-info {
  flex: 1;
}

.follow-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.follow-phone {
  font-size: 26rpx;
  color: #999999;
}

.follow-action {
  margin-left: 20rpx;
}

.unfollow-btn {
  width: 160rpx;
  height: 60rpx;
  font-size: 26rpx;
  line-height: 60rpx;
  color: #666666;
  background-color: #f0f0f0;
  border-radius: 30rpx;
  border: none;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
  padding: 0 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
}