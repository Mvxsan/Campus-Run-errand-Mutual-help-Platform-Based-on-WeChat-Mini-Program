<scroll-view
  class="container"
  scroll-y
  type="list"
  bindrefresherpulling="onPullDownRefresh"
  bindrefresherrefresh="onPullDownRefresh"
  refresher-enabled="true"
  refresher-background="#f5f5f5"
  refresher-triggered="{{ refresherTriggered }}"
>
  <!-- 用户信息区域 -->
  <view class="user-info-section" bindtap="navigateToUserInfo">
    <view class="user-avatar">
      <image
        class="avatar-img"
        src="{{
          userInfo
            ? userInfo.avatar &&
              (userInfo.avatar.indexOf('http://tmp/') === 0 ||
                userInfo.avatar.indexOf('_tmp_') > 0)
              ? 'https://img.icons8.com/color/48/000000/user.png'
              : userInfo.avatar
            : 'https://img.icons8.com/color/48/000000/user.png'
        }}"
        mode="aspectFill"
      ></image>
    </view>
    <view class="user-details">
      <text class="user-name">{{
        userInfo ? userInfo.nickname || "未设置昵称" : "点击登录"
      }}</text>
      <text class="user-phone">{{
        userInfo ? userInfo.phone || "未绑定手机号" : "登录后查看个人信息"
      }}</text>
    </view>
    <view class="arrow-icon">
      <text class="arrow-text">→</text>
    </view>
  </view>

  <!-- 任务统计区域 -->
  <view class="stats-section" wx:if="{{ userInfo }}">
    <view class="stats-grid">
      <view class="stats-item">
        <text class="stats-value">{{ stats.publishedTasks || 0 }}</text>
        <text class="stats-label">{{
          userInfo && userInfo.phone === "admin" && userInfo.role === 1
            ? "总发布任务"
            : "发布任务"
        }}</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{ stats.acceptedTasks || 0 }}</text>
        <text class="stats-label">{{
          userInfo && userInfo.phone === "admin" && userInfo.role === 1
            ? "总接取任务"
            : "接取任务"
        }}</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{ stats.completedTasks || 0 }}</text>
        <text class="stats-label">{{
          userInfo && userInfo.phone === "admin" && userInfo.role === 1
            ? "总完成任务"
            : "完成任务"
        }}</text>
      </view>
      <view
        class="stats-item"
        wx:if="{{
          userInfo && userInfo.phone === 'admin' && userInfo.role === 1
        }}"
      >
        <text class="stats-value">{{ stats.disabledTasks || 0 }}</text>
        <text class="stats-label">已禁止任务</text>
      </view>
      <view class="stats-item" wx:else>
        <text class="stats-value">{{
          userRating > 0 ? userRating + ".0" : "暂无评分"
        }}</text>
        <text class="stats-label">评分</text>
      </view>
    </view>
  </view>

  <!-- 资金信息区域 -->
  <view
    class="fund-section"
    wx:if="{{ userInfo }}"
    bindtap="navigateToWithdrawal"
  >
    <view class="fund-item">
      <text class="fund-label">资金余额</text>
      <view class="fund-value-container">
        <text class="fund-value">¥{{ userInfo.balance || 0.0 }}</text>
        <text class="fund-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单区域 - 四宫格 -->
  <view class="menu-section" wx:if="{{ userInfo }}">
    <!-- 第一行菜单 -->
    <view class="menu-grid">
      <view class="menu-item" bindtap="handleMyFollow">
        <view class="menu-icon">
          <text class="menu-icon-text">👥</text>
        </view>
        <text class="menu-text">我的关注</text>
      </view>
      <view class="menu-item" bindtap="handleMyEvaluation">
        <view class="menu-icon">
          <text class="menu-icon-text">⭐</text>
        </view>
        <text class="menu-text">我的评价</text>
      </view>
      <view class="menu-item" bindtap="handleMyLikes">
        <view class="menu-icon">
          <text class="menu-icon-text">👍</text>
        </view>
        <text class="menu-text">我的点赞</text>
      </view>
    </view>

    <!-- 第二行菜单 -->
    <view class="menu-list">
      <view class="list-item" bindtap="handleCampusRules">
        <view class="list-icon">
          <text class="list-icon-text">📋</text>
        </view>
        <text class="list-text">校园互助规则</text>
        <view class="arrow-icon">
          <text class="arrow-text">→</text>
        </view>
      </view>
      <view
        class="list-item"
        bindtap="navigateToAdmin"
        wx:if="{{
          userInfo && userInfo.phone === 'admin' && userInfo.role === 1
        }}"
      >
        <view class="list-icon">
          <text class="list-icon-text">👥</text>
        </view>
        <text class="list-text">用户管理</text>
        <view class="arrow-icon">
          <text class="arrow-text">→</text>
        </view>
      </view>
      <view
        class="list-item"
        bindtap="handleContactService"
        wx:if="{{
          userInfo && (userInfo.phone !== 'admin' || userInfo.role !== 1)
        }}"
      >
        <view class="list-icon">
          <text class="list-icon-text">📞</text>
        </view>
        <text class="list-text">联系客服</text>
        <view class="arrow-icon">
          <text class="arrow-text">→</text>
        </view>
      </view>
      <view
        class="list-item"
        bindtap="navigateToAccountSecurity"
        wx:if="{{
          userInfo && (userInfo.phone !== 'admin' || userInfo.role !== 1)
        }}"
      >
        <view class="list-icon">
          <text class="list-icon-text">🔒</text>
        </view>
        <text class="list-text">账号与安全</text>
        <view class="arrow-icon">
          <text class="arrow-text">→</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-section" wx:if="{{ userInfo }}">
    <text class="version-text">版本 v1.0.0</text>
  </view>

  <!-- 退出登录按钮 -->
  <view class="logout-section" wx:if="{{ userInfo }}">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
</scroll-view>
