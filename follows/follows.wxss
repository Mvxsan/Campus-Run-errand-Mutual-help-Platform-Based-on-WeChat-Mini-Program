/* follows.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background-color: #ffffff;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-left {
  width: 44rpx;
}

.nav-back {
  font-size: 36rpx;
  color: #333333;
  font-weight: bold;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.nav-right {
  width: 44rpx;
}

/* 关注列表 */
.follows-section {
  flex: 1;
  background-color: #ffffff;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.section-count {
  font-size: 24rpx;
  color: #999999;
}

.follows-list {
  display: flex;
  flex-direction: column;
}

.follow-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.user-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.unfollow-btn {
  padding: 8rpx 24rpx;
  background-color: #f0f0f0;
  color: #666666;
  font-size: 22rpx;
  border-radius: 20rpx;
  border: none;
  margin-right: 16rpx;
}

.unfollow-btn::after {
  border-radius: 20rpx;
}

.arrow-icon {
  font-size: 32rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  color: #999999;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 22rpx;
  color: #999999;
  text-align: center;
  line-height: 1.4;
}

/* 点击效果 */
.follow-item:active {
  background-color: #f5f5f5;
}
